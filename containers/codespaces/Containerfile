FROM registry.redhat.io/devspaces/udi-base-rhel10:3.29

USER root

ARG TARGETARCH

# install centos stream & fedora repos, other vars
ENV ARCH=${TARGETARCH:-arm64} \
    HOME=/home/tooling \
    APP_ROOT=/home/tooling \
    XDG_CONFIG_HOME=/home/tooling/.config 

# set the virtual environment for jumpstarter etc
ENV UV_PYTHON=python3.14 VIRTUAL_ENV=/venv

# install this repository's version of jumpstarter
#ENV JUMPSTARTER_VERSION=main \
#    JUMPSTARTER_REPO=https://github.com/jumpstarter-dev/jumpstarter

# install epel releases
RUN dnf install -y --setopt=tsflags=nodocs https://dl.fedoraproject.org/pub/epel/epel-release-latest-10.noarch.rpm && \
    dnf install -y epel-release 

# install basic packages
RUN dnf install -y --setopt=tsflags=nodocs \
    nss_wrapper kmod openssh-clients nc \
    fuse-overlayfs slirp4netns shadow-utils \
    patch lsof redhat-rpm-config procps-ng \
    unzip wget bzip2 zip which rpm-build 

# install development dependencies
RUN dnf install -y --setopt=tsflags=nodocs \
    python3.14 python3.14-devel python3-pip \
    git jq  yq \
    cmake automake autoconf make \
    gcc gcc-c++ golang \
    gdb gd-devel glibc-devel openssl-devel \
    sqlite-devel zlib-devel libcurl-devel libpq-devel \
    libxml2-devel libxslt-devel 

# createrepo_c is in CentOS Stream 10 AppStream, not UBI/EPEL (the old createrepo package is gone)
RUN arch=$(uname -m) && \
    printf '%s\n' \
    '[cs10-appstream]' \
    'name=CentOS Stream 10 AppStream' \
    "baseurl=https://mirror.stream.centos.org/10-stream/AppStream/${arch}/os/" \
    'enabled=1' \
    'gpgcheck=0' \
    > /etc/yum.repos.d/cs10-appstream.repo && \
    dnf install -y --setopt=tsflags=nodocs createrepo_c && \
    rm -f /etc/yum.repos.d/cs10-appstream.repo

ENV OC_VERSION=4.21 \
    K8S_VERSION=1.34 \
    KUBECONFIG=/home/user/.kube/config

# oc client
RUN if [ "$ARCH" = "arm64" ]; then \
        curl -L https://mirror.openshift.com/pub/openshift-v4/arm64/clients/ocp/stable-${OC_VERSION}/openshift-client-linux.tar.gz; \
    else \
        curl -L https://mirror.openshift.com/pub/openshift-v4/x86_64/clients/ocp/stable-${OC_VERSION}/openshift-client-linux.tar.gz; \
    fi | tar -C /usr/local/bin -xz --no-same-owner && \
    chmod +x /usr/local/bin/oc
  
## kubectl
RUN <<EOF
set -euf -o pipefail

cat <<EOF2 > /etc/yum.repos.d/kubernetes.repo
[kubernetes]
name=Kubernetes
baseurl=https://pkgs.k8s.io/core:/stable:/v${K8S_VERSION}/rpm/
enabled=1
gpgcheck=1
gpgkey=https://pkgs.k8s.io/core:/stable:/v${K8S_VERSION}/rpm/repodata/repomd.xml.key
EOF2

dnf install --setopt=tsflags=nodocs -y kubectl
curl -sSL -o ~/.kubectl_aliases https://raw.githubusercontent.com/ahmetb/kubectl-alias/master/.kubectl_aliases
EOF

# install node (x64 binaries require libatomic)
ARG NODE_VERSION=26.5.0
RUN dnf install -y --setopt=tsflags=nodocs libatomic && \
    set -e; \
    if [ "$ARCH" = "arm64" ]; then \
        node_arch=arm64; \
    else \
        node_arch=x64; \
    fi; \
    curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${node_arch}.tar.xz" \
        -o /tmp/node.tar.xz && \
    tar -xJf /tmp/node.tar.xz -C /usr/local --strip-components=1 && \
    rm /tmp/node.tar.xz && \
    node --version && npm --version

# install rust
ENV CARGO_HOME=${APP_ROOT}/.cargo \
    RUSTUP_HOME=${APP_ROOT}/.rustup \
    PATH=${APP_ROOT}/.cargo/bin:${PATH}
    
RUN mkdir -p $RUSTUP_HOME $CARGO_HOME && \
    curl --proto '=https' --tlsv1.2 -sSfo rustup https://sh.rustup.rs && \
    chmod +x rustup && mv rustup /usr/bin/ && \
    rustup -y --no-modify-path --profile minimal -c rust-src -c rust-analysis -c rls
    
# install protobuf compiler
RUN mkdir -p /home/tooling/protobuf && \
    if [ "$ARCH" = "arm64" ]; then \
        URL=$(curl -s https://api.github.com/repos/protocolbuffers/protobuf/releases/latest \
        | jq -r '.assets[] | select(.name | endswith("linux-aarch_64.zip")) | .browser_download_url') && \
        curl -LO "$URL"; \
    else \
        URL=$(curl -s https://api.github.com/repos/protocolbuffers/protobuf/releases/latest \
        | jq -r '.assets[] | select(.name | endswith("linux-x86_64.zip")) | .browser_download_url') && \
        curl -LO "$URL"; \
    fi && \
    unzip "$(basename "$URL")" -d "/home/tooling/protobuf"
    
# install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv  /bin/uv
COPY --from=ghcr.io/astral-sh/uv:latest /uvx /bin/uvx

# install jumpstarter & other python dependencies
#COPY requirements.txt /tmp/requirements.txt

#RUN uv venv /venv && \
#    uv pip install "git+${JUMPSTARTER_REPO}@${JUMPSTARTER_VERSION}#subdirectory=python/packages/jumpstarter-all" && \
#    uv pip install -r /tmp/requirements.txt && \
#    rm -rf /tmp/requirements.txt

# jmp-login script
#COPY scripts/jmp-login /usr/local/bin/jmp-login
#RUN chmod +x /usr/local/bin/jmp-login

# init-workspace script
COPY scripts/init-workspace /usr/local/bin/init-workspace
RUN chmod +x /usr/local/bin/init-workspace

# Install Claude Code, using direct binary download instead of the install.sh script to avoid OOM-killing
# the binary's post-install setup step in memory-constrained container builds.
#RUN set -e; \
#    mkdir -p /home/tooling/bin /home/tooling/.claude && \
#    arch=$(uname -m | sed 's/x86_64/x64/;s/aarch64/arm64/'); \
#    if ldd /bin/ls 2>&1 | grep -q musl || [ -f /lib/libc.musl-x86_64.so.1 ] || [ -f /lib/libc.musl-aarch64.so.1 ]; then \
#        platform="linux-${arch}-musl"; \
#    else \
#        platform="linux-${arch}"; \
#    fi; \
#    version=$(curl -fsSL https://downloads.claude.ai/claude-code-releases/latest); \
#    curl -fsSL -o /home/tooling/bin/claude "https://downloads.claude.ai/claude-code-releases/${version}/${platform}/claude"; \
#    chmod +x /home/tooling/bin/claude

# clean up
RUN dnf -y clean all --enablerepo='*' && \
    rm -rf /var/cache/dnf

# A last pass to make sure that an arbitrary user can write in $HOME
RUN chgrp -R 0 /home && chmod -R g=u /home

USER 10001
ENV HOME=/home/user
WORKDIR /projects